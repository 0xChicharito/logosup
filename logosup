#!/usr/bin/env bash
set -euo pipefail

# ── Resolve script location ──────────────────────────────────────────
# Works even when called via symlink (logosnode -> logos-node)
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd -P)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd -P)"

LOGOS_NODE_LIB="$SCRIPT_DIR/lib"
LOGOS_NODE_CLI_VERSION="$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "unknown")"
LOGOS_NODE_DIR="${LOGOS_NODE_DIR:-$HOME/.logos-node}"

# Save original invocation for potential re-exec (e.g., sg docker group activation)
LOGOS_NODE_ENTRY="$SCRIPT_SOURCE"
LOGOS_NODE_ARGS=("$@")

export LOGOS_NODE_LIB LOGOS_NODE_DIR LOGOS_NODE_ENTRY

# ── Source core libraries ─────────────────────────────────────────────
source "$LOGOS_NODE_LIB/common.sh"
source "$LOGOS_NODE_LIB/config.sh"
source "$LOGOS_NODE_LIB/releases.sh"
source "$LOGOS_NODE_LIB/docker.sh"

# ── Load config ───────────────────────────────────────────────────────
# `update` and `reset` interactively prompt for drift cleanup themselves —
# suppress the passive warning so the user only sees one notification.
case "${1:-}" in
    update|reset) export LOGOS_DRIFT_WARNED=1 ;;
esac
load_config

# ── Help ──────────────────────────────────────────────────────────────
print_usage() {
    print_banner
    echo -e "${BOLD}Usage:${RESET} logosup <command> [options]"
    echo ""
    echo -e "${BOLD}Commands:${RESET}"
    echo -e "  ${CYAN}install${RESET}    Install and set up the Logos Blockchain node"
    echo -e "  ${CYAN}start${RESET}      Start the node"
    echo -e "  ${CYAN}stop${RESET}       Stop the node"
    echo -e "  ${CYAN}status${RESET}     Show node status and health"
    echo -e "  ${CYAN}logs${RESET}       View node logs"
    echo -e "  ${CYAN}update${RESET}     Update the node and/or CLI tool"
    echo -e "  ${CYAN}reset${RESET}      Wipe local data and regenerate config (use after breaking releases)"
    echo -e "  ${CYAN}keys${RESET}       Show, backup, or restore wallet keys"
    echo -e "  ${CYAN}wallet${RESET}     Send transfers, check balance, look up transactions"
    echo -e "  ${CYAN}faucet${RESET}     Open the faucet and display wallet keys"
    echo -e "  ${CYAN}inscribe${RESET}   Publish text inscriptions to the blockchain"
    echo -e "  ${CYAN}monitor${RESET}    Manage monitoring dashboard (Grafana + Prometheus)"
    echo -e "  ${CYAN}security${RESET}   Scan and harden server security"
    echo -e "  ${CYAN}help${RESET}       Show this help message"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo "  logosup install                    # First-time setup"
    echo "  logosup start                      # Start the node"
    echo "  logosup status                     # Check node health"
    echo "  logosup logs -f                    # Follow logs"
    echo "  logosup update                     # Update node + CLI"
    echo "  logosup update -b dev              # Switch CLI to a branch"
    echo "  logosup reset                      # Wipe data + regen config (after breaking release)"
    echo "  logosup wallet balance             # Show wallet balances"
    echo "  logosup wallet transfer <to> 100   # Send 100 to recipient"
    echo "  logosup monitor auth on            # Require Grafana login"
    echo "  logosup inscribe                   # Inscribe text on-chain"
    echo "  logosup security                   # Check server security"
    echo ""
    echo -e "${BOLD}Config:${RESET} $LOGOS_NODE_DIR"
    echo ""
}

# ── Command dispatch ──────────────────────────────────────────────────
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    help|-h|--help)
        print_usage
        exit 0
        ;;
    version|-v|--version)
        echo "logosup CLI v${LOGOS_NODE_CLI_VERSION}"
        echo "Node version: ${LOGOS_NODE_VERSION:-not installed}"
        exit 0
        ;;
    *)
        CMD_FILE="$LOGOS_NODE_LIB/cmd_${COMMAND}.sh"
        if [[ -f "$CMD_FILE" ]]; then
            source "$CMD_FILE"
            "cmd_${COMMAND}" "$@"
        else
            log_error "Unknown command: $COMMAND"
            echo ""
            print_usage
            exit 1
        fi
        ;;
esac
