      "id": 212,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Memory Usage",
      "description": "Flat line at 0 B on Raspberry Pi means memory cgroups aren't enabled in the kernel. Add `cgroup_enable=memory cgroup_memory=1` to /boot/firmware/cmdline.txt and reboot. `docker stats` showing 0B/0B for MEM is the same root cause.",
      "type": "timeseries",
      "targets": [
        { "expr": "logos_container_memory_bytes", "legendFormat": "Used", "refId": "A" },
        { "expr": "logos_container_memory_limit_bytes", "legendFormat": "Limit", "refId": "B" }
      ]
    },
